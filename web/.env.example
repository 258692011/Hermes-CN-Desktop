# Hermes Dashboard origin (default: http://127.0.0.1:9119)
# Override when running dashboard on a non-standard port
# HERMES_DASHBOARD_ORIGIN=http://127.0.0.1:9119

# HERMES_HOME override (default: ~/.hermes)
# HERMES_HOME=/path/to/hermes-home

# Gateway transport: "sse" (default) or "ws"
# VITE_HERMES_TRANSPORT=sse

# Provider catalog remote source (default: desktop.hermesagent.org.cn/api/provider-catalog.json)
# Override to point the Models page preset catalog at a different JSON (e.g. staging)
# VITE_HERMES_PROVIDER_CATALOG_URL=https://desktop.hermesagent.org.cn/api/provider-catalog.json
